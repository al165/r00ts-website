{
    "version": 8,
    "name": "OSM Liberty",
    "metadata": {
        "maputnik:license": "https://github.com/maputnik/osm-liberty/blob/gh-pages/LICENSE.md",
        "maputnik:renderer": "mbgljs",
        "openmaptiles:version": "3.x"
    },
    "sources": {
        "openmaptiles": {
            "type": "vector",
            "url": "https://tiles.openfreemap.org/planet"
        }
    },
    "sprite": "https://maputnik.github.io/osm-liberty/sprites/osm-liberty",
    "layers": [
        {
            "id": "background",
            "type": "background",
            "layout": {
                "visibility": "visible"
            },
            "paint": {
                "background-color": "rgba(0, 0, 255, 1)"
            }
        },
        {
            "id": "park",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "park",
            "paint": {
                "fill-color": "rgba(255, 0, 255, 1)",
                "fill-opacity": 1
            }
        },
        {
            "id": "landuse_residential",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landuse",
            "maxzoom": 24,
            "filter": [
                "==",
                "class",
                "residential"
            ],
            "paint": {
                "fill-color": "rgba(0, 255, 0, 1)"
            }
        },
        {
            "id": "landcover_wood",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landcover",
            "filter": [
                "all",
                [
                    "==",
                    "class",
                    "wood"
                ]
            ],
            "paint": {
                "fill-antialias": false,
                "fill-color": "rgba(0, 255, 255, 1)",
                "fill-opacity": 1
            }
        },
        {
            "id": "landcover_grass",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landcover",
            "filter": [
                "all",
                [
                    "==",
                    "class",
                    "grass"
                ]
            ],
            "layout": {
                "visibility": "visible"
            },
            "paint": {
                "fill-antialias": false,
                "fill-color": "rgba(255, 0, 238, 1)",
                "fill-opacity": 1
            }
        },
        {
            "id": "landcover_ice",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landcover",
            "filter": [
                "all",
                [
                    "==",
                    "class",
                    "ice"
                ]
            ],
            "layout": {
                "visibility": "visible"
            },
            "paint": {
                "fill-antialias": false,
                "fill-color": "rgba(0, 0, 255, 1)",
                "fill-opacity": 0.8
            }
        },
        {
            "id": "landcover_wetland",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landcover",
            "minzoom": 12,
            "filter": [
                "all",
                [
                    "==",
                    "class",
                    "wetland"
                ]
            ],
            "layout": {
                "visibility": "none"
            },
            "paint": {
                "fill-antialias": true,
                "fill-opacity": 0.8,
                "fill-pattern": "wetland_bg_11",
                "fill-translate-anchor": "map"
            }
        },
        {
            "id": "landuse_pitch",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landuse",
            "filter": [
                "==",
                "class",
                "pitch"
            ],
            "layout": {
                "visibility": "visible"
            },
            "paint": {
                "fill-color": "rgba(255, 0, 255, 1)"
            }
        },
        {
            "id": "water",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "water",
            "maxzoom": 24,
            "filter": [
                "all",
                [
                    "!=",
                    "brunnel",
                    "tunnel"
                ]
            ],
            "layout": {
                "visibility": "visible"
            },
            "paint": {
                "fill-color": "rgba(0, 0, 0, 1)"
            }
        },
        {
            "id": "landcover_sand",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landcover",
            "filter": [
                "all",
                [
                    "==",
                    "class",
                    "sand"
                ]
            ],
            "layout": {
                "visibility": "visible"
            },
            "paint": {
                "fill-color": "rgba(0, 0, 255, 1)"
            }
        },
        {
            "id": "aeroway_fill",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "aeroway",
            "minzoom": 11,
            "filter": [
                "==",
                "$type",
                "Polygon"
            ],
            "layout": {
                "visibility": "none"
            },
            "paint": {
                "fill-color": "rgba(255, 206, 0, 0)",
                "fill-opacity": 0.7
            }
        },
        {
            "id": "road_area_pattern",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": [
                "all",
                [
                    "==",
                    "$type",
                    "Polygon"
                ]
            ],
            "layout": {
                "visibility": "none"
            },
            "paint": {
                "fill-pattern": "pedestrian_polygon"
            }
        },
        {
            "id": "building",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "building",
            "minzoom": 0,
            "maxzoom": 24,
            "layout": {
                "visibility": "none"
            },
            "paint": {
                "fill-color": "rgba(227, 19, 201, 1)",
                "fill-outline-color": "hsla(35, 6%, 79%, 0.32)"
            }
        },
        {
            "id": "road",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "layout": {
                "visibility": "none"
            }
        },
        {
            "id": "landcover_forest",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landcover",
            "layout": {
                "visibility": "none"
            }
        }
    ],
    "id": "osm-liberty"
}
